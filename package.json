{
  "name": "coding-world",
  "version": "1.0.0",
  "description": "Coding World - Full Stack Portfolio with Internship System",
  "private": true,
  "scripts": {
    "start": "node server/server.js",
    "server": "node server/server.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "server:dev": "nodemon server/server.js",
    "install-client": "npm install --prefix client",
    "install-server": "npm install --prefix server",
    "install-all": "npm install && npm run install-client && npm run install-server",
    "build": "npm run build --prefix client",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "prod": "NODE_ENV=production npm run start",
    "clean": "rm -rf node_modules client/node_modules server/node_modules",
    "clean:all": "npm run clean && rm -rf client/build server/uploads",
    "heroku-postbuild": "npm run install-client && npm run build:client"
  },
  "keywords": [
    "react",
    "node",
    "mongodb",
    "portfolio",
    "internship",
    "fullstack"
  ],
  "author": "Coding World",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/coding-world.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/coding-world/issues"
  },
  "homepage": "https://github.com/yourusername/coding-world#readme"
}